#: app/flat_maker.py:178
#, python-format
msgid "Please choose Yes or No for %(field)s."
msgstr "Ju lutem zgjidhni Po ose Jo per %(field)s."

#: app/flat_maker.py:246
msgid "Choose a folder to save the file"
msgstr "Zgjidhni nje dosje per te ruajtur skedarin"

#: app/messages.py:6
msgid ""
"Image Link #1 warning: the design must cover at least 75 percent of the "
"full room/staged image."
msgstr ""
"Paralajmerim per Lidhjen e imazhit #1: dizajni duhet te mbuloje te pakten 75 "
"perqind te imazhit te plote te dhomes ose skenes."

#: app/messages.py:7
msgid "Press Enter to autofill."
msgstr "Enter = auto"

#: app/messages.py:8
msgid ""
"Please fill in the required fields and choose the required options, and "
"enter valid values in the highlighted fields."
msgstr ""
"Ju lutem plotesoni fushat e detyrueshme dhe zgjidhni opsionet e "
"detyrueshme, si edhe vendosni vlera te sakta ne fushat e theksuara."

#: app/messages.py:9
msgid "Please fill in the required fields and choose the required options."
msgstr "Ju lutem plotesoni fushat e detyrueshme dhe zgjidhni opsionet e detyrueshme."

#: app/messages.py:10
msgid "Please enter valid values in the highlighted fields."
msgstr "Ju lutem vendosni vlera te sakta ne fushat e theksuara."

#: app/messages.py:11
msgid "Please fix the highlighted fields."
msgstr "Ju lutem korrigjoni fushat e theksuara."

#: app/messages.py:12
#, python-format
msgid "%(field)s is required."
msgstr "Fusha %(field)s eshte e detyrueshme."

#: app/messages.py:13
#, python-format
msgid "Links are not allowed in %(field)s."
msgstr "Lidhjet nuk lejohen ne fushen %(field)s."

#: app/messages.py:14
#, python-format
msgid "Enter a valid URL for %(field)s."
msgstr "Vendosni nje URL te vlefshem per %(field)s."

