msgid "Yes"
msgstr "Po"

#: app/ui_ops.py:80 app/ui_ops.py:82
msgid "No"
msgstr "Jo"

#: app/ui_ops.py:88
msgid "Width"
msgstr "Gjeresia"

#: app/ui_ops.py:91
msgid "Height"
msgstr "Lartesia"

