#: app/builder.py:16 app/ui_ops.py:33
msgid "Language"
msgstr "Мова"

#: app/builder.py:26 app/submission.py:36 app/ui_ops.py:24
msgid ""
"Does the design have personalization\n"
"(e.g., text from the client)?"
msgstr ""
"Дизайн має персоналізацію\n"
"(наприклад, текст від клієнта)?"

#: app/builder.py:43 app/submission.py:27 app/ui_ops.py:22
msgid "Does the design have color variations?"
msgstr "Дизайн має варіації за кольором?"

#: app/builder.py:80 app/ui_ops.py:37
msgid "Generate Spreadsheet"
msgstr "Сформувати таблицю"

#: app/builder.py:98 app/ui_ops.py:26
msgid "Sizes and prices"
msgstr "Розміри та ціни"

#: app/builder.py:100 app/ui_ops.py:27
msgid "Print Type"
msgstr "Тип друку"

#: app/builder.py:103 app/ui_ops.py:28
msgid "Decals"
msgstr "Декалі"

#: app/builder.py:104 app/ui_ops.py:29
msgid "Wallpapers"
msgstr "Шпалери"

#: app/builder.py:110 app/ui_ops.py:30
msgid "Listing Title"
msgstr "Назва лістингу"

#: app/builder.py:118 app/ui_ops.py:32
msgid "e.g.: VN007"
msgstr "Наприклад: VN007"

#: app/builder.py:123 app/ui_ops.py:34
msgid "Keywords"
msgstr "Ключова фраза"

#: app/builder.py:125 app/ui_ops.py:35
msgid "e.g. (in plural): Dog Wall Stickers"
msgstr "Наприклад (у множині): Dog Wall Stickers"

#: app/flat_maker.py:178
#, python-format
msgid "Please choose Yes or No for %(field)s."
msgstr "Будь ласка, виберіть Так або Ні для %(field)s."

#: app/flat_maker.py:246
msgid "Choose a folder to save the file"
msgstr "Оберіть папку для збереження файлу"

#: app/messages.py:6
msgid ""
"Image Link #1 warning: the design must cover at least 75 percent of the "
"full room/staged image."
msgstr ""
"Попередження для Посилання на зображення #1: дизайн має займати щонайменше 75 відсотків "
"усього зображення кімнати або сцени."

#: app/messages.py:7
msgid "Press Enter to autofill."
msgstr "Enter = автозап."

#: app/messages.py:8
msgid ""
"Please fill in the required fields and choose the required options, and "
"enter valid values in the highlighted fields."
msgstr ""
"Будь ласка, заповніть обов'язкові поля та виберіть обов'язкові опції, а "
"також введіть коректні значення у виділені поля."

#: app/messages.py:9
msgid "Please fill in the required fields and choose the required options."
msgstr "Будь ласка, заповніть обов'язкові поля та виберіть обов'язкові опції."

#: app/messages.py:10
msgid "Please enter valid values in the highlighted fields."
msgstr "Будь ласка, введіть коректні значення у виділені поля."

#: app/messages.py:11
msgid "Please fix the highlighted fields."
msgstr "Будь ласка, виправте виділені поля."

#: app/messages.py:12
#, python-format
msgid "%(field)s is required."
msgstr "Поле %(field)s є обов'язковим."

#: app/messages.py:13
#, python-format
msgid "Links are not allowed in %(field)s."
msgstr "Посилання не дозволені в полі %(field)s."

#: app/messages.py:14
#, python-format
msgid "Enter a valid URL for %(field)s."
msgstr "Введіть коректний URL для %(field)s."

#: app/submission.py:174
msgid "Spreadsheet generated"
msgstr "Таблицю сформовано"

#: app/submission.py:184
#, python-format
msgid "Error: %(err)s"
msgstr "Помилка: %(err)s"

#: app/ui_ops.py:38 app/ui_ops.py:40
msgid "Yes"
msgstr "Так"

#: app/ui_ops.py:39 app/ui_ops.py:41
msgid "No"
msgstr "Ні"

#: app/ui_ops.py:45
msgid "Width"
msgstr "Ширина"

#: app/ui_ops.py:48
msgid "Height"
msgstr "Висота"

#: app/ui_ops.py:51
msgid "Price"
msgstr "Ціна"

#: app/ui_ops.py:56 app/ui_ops.py:105
msgid "Image Link"
msgstr "Посилання на зображення"
