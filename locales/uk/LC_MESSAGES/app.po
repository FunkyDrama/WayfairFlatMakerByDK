#: app/builder.py:25 app/ui_ops.py:73
msgid "Language"
msgstr "Мова"

#: app/builder.py:35 app/submission.py:57 app/ui_ops.py:64
msgid ""
"Does the design have personalization\n"
"(e.g., text from the client)?"
msgstr ""
"Дизайн має персоналізацію\n"
"(наприклад, текст від клієнта)?"

#: app/builder.py:52 app/submission.py:48 app/ui_ops.py:62
msgid "Does the design have color variations?"
msgstr "Дизайн має варіації за кольором?"

#: app/builder.py:78 app/flat_maker.py:296 app/messages.py:25 app/ui_ops.py:76
msgid "✨ Suggest title & keywords"
msgstr "✨ Запропонувати назву та ключову фразу"

#: app/builder.py:97 app/submission.py:281 app/ui_ops.py:78
msgid "Generate Spreadsheet"
msgstr "Сформувати таблицю"

#: app/builder.py:115 app/ui_ops.py:66
msgid "Sizes"
msgstr "Розміри"

#: app/builder.py:117 app/ui_ops.py:67
msgid "Print Type"
msgstr "Тип друку"

#: app/builder.py:120 app/ui_ops.py:68
msgid "Decals"
msgstr "Декалі"

#: app/builder.py:121 app/ui_ops.py:69
msgid "Wallpapers"
msgstr "Шпалери"

#: app/builder.py:127 app/ui_ops.py:70
msgid "Listing Title"
msgstr "Назва лістингу"

#: app/builder.py:135 app/ui_ops.py:72
msgid "e.g.: VN007"
msgstr "Наприклад: VN007"

#: app/builder.py:140 app/ui_ops.py:74
msgid "Keywords"
msgstr "Ключова фраза"

#: app/builder.py:142 app/ui_ops.py:56
msgid "e.g. (in plural): Dog Wall Stickers"
msgstr "Наприклад (у множині): Dog Wall Stickers"

#: app/flat_maker.py:252 app/messages.py:23
#, python-format
msgid "Enter a valid URL for %(field)s."
msgstr "Введіть коректний URL для %(field)s."

#: app/flat_maker.py:253 app/ui_ops.py:98 app/ui_ops.py:165
msgid "Image Link"
msgstr "Посилання на зображення"

#: app/flat_maker.py:263 app/messages.py:26 app/submission.py:209
msgid "Generating..."
msgstr "Генерація..."

#: app/flat_maker.py:275 app/messages.py:27
msgid "Title and keywords generated"
msgstr "Назву та ключову фразу згенеровано"

#: app/flat_maker.py:288 app/messages.py:45
msgid ""
"AI could not generate a title and keywords. Try again or fill them "
"manually."
msgstr ""
"AI не зміг згенерувати назву та ключову фразу. Спробуйте ще раз або "
"заповніть їх вручну."

#: app/flat_maker.py:325
#, python-format
msgid "Please choose Yes or No for %(field)s."
msgstr "Будь ласка, виберіть Так або Ні для %(field)s."

#: app/flat_maker.py:423
msgid "Choose a folder to save the file"
msgstr "Оберіть папку для збереження файлу"

#: app/messages.py:12
msgid ""
"Image Link #1 warning: the design must cover at least 75 percent of the "
"full room/staged image."
msgstr ""
"Попередження для Посилання на зображення #1: дизайн має займати "
"щонайменше 75 відсотків усього зображення кімнати або сцени."

#: app/messages.py:14
msgid "Press Enter to autofill."
msgstr "Enter = автозап."

#: app/messages.py:16
msgid ""
"Please fill in the required fields and choose the required options, and "
"enter valid values in the highlighted fields."
msgstr ""
"Будь ласка, заповніть обов'язкові поля та виберіть обов'язкові опції, а "
"також введіть коректні значення у виділені поля."

#: app/messages.py:18
msgid "Please fill in the required fields and choose the required options."
msgstr "Будь ласка, заповніть обов'язкові поля та виберіть обов'язкові опції."

#: app/messages.py:19
msgid "Please enter valid values in the highlighted fields."
msgstr "Будь ласка, введіть коректні значення у виділені поля."

#: app/messages.py:20
msgid "Please fix the highlighted fields."
msgstr "Будь ласка, виправте виділені поля."

#: app/messages.py:21
#, python-format
msgid "%(field)s is required."
msgstr "Поле %(field)s є обов'язковим."

#: app/messages.py:22
#, python-format
msgid "Links are not allowed in %(field)s."
msgstr "Посилання не дозволені в полі %(field)s."

#: app/messages.py:24 app/ui_ops.py:55
msgid "e.g. (in plural): Dog Wallpapers"
msgstr "Наприклад (у множині): Dog Wallpapers"

#: app/messages.py:28
msgid "AI generation is not configured. Please contact the administrator."
msgstr "AI-генерацію не налаштовано. Зверніться до адміністратора."

#: app/messages.py:29
msgid "AI text generation is not configured. Standard template text was used."
msgstr ""
"AI-генерацію тексту не налаштовано. Використано стандартний шаблонний "
"текст."

#: app/messages.py:30
msgid ""
"AI generation is not configured correctly. Please contact the "
"administrator."
msgstr "AI-генерацію налаштовано некоректно. Зверніться до адміністратора."

#: app/messages.py:31
msgid "AI limit was reached. Try again later."
msgstr "Ліміт AI вичерпано. Спробуйте пізніше."

#: app/messages.py:32
msgid "AI limit was reached. Standard template text was used. Try again later."
msgstr ""
"Ліміт AI вичерпано. Використано стандартний шаблонний текст. Спробуйте "
"пізніше."

#: app/messages.py:33
msgid "AI service is temporarily unavailable. Try again later."
msgstr "AI-сервіс тимчасово недоступний. Спробуйте пізніше."

#: app/messages.py:34
msgid "AI service is temporarily unavailable. Standard template text was used."
msgstr "AI-сервіс тимчасово недоступний. Використано стандартний шаблонний текст."

#: app/messages.py:35
msgid "AI generation failed. Try again later."
msgstr "AI-генерація не вдалася. Спробуйте пізніше."

#: app/messages.py:36
msgid "AI generation failed. Standard template text was used."
msgstr "AI-генерація не вдалася. Використано стандартний шаблонний текст."

#: app/messages.py:37 app/submission.py:114
msgid "AI text generation failed. Standard template text was used."
msgstr "AI-генерація тексту не вдалася. Використано стандартний шаблонний текст."

#: app/messages.py:38
msgid ""
"AI could not download the main image. Check that the image link opens "
"publicly."
msgstr ""
"AI не зміг завантажити головне зображення. Перевірте, що посилання на "
"зображення відкривається публічно."

#: app/messages.py:39
msgid "AI could not read the main image. Please use another image link."
msgstr "AI не зміг прочитати головне зображення. Використайте інше посилання."

#: app/messages.py:40
msgid "The main image is too large for AI analysis. Please use a smaller image."
msgstr ""
"Головне зображення завелике для AI-аналізу. Використайте зображення "
"меншого розміру."

#: app/messages.py:41
msgid "AI did not return usable text. Try again."
msgstr "AI не повернув придатний текст. Спробуйте ще раз."

#: app/messages.py:42
msgid "AI returned an unexpected answer. Try again."
msgstr "AI повернув неочікувану відповідь. Спробуйте ще раз."

#: app/messages.py:43
msgid "AI returned incomplete text. Try again."
msgstr "AI повернув неповний текст. Спробуйте ще раз."

#: app/messages.py:44
msgid ""
"AI could not create a title and keywords from this image. Try again or "
"fill them manually."
msgstr ""
"AI не зміг створити назву та ключову фразу за цим зображенням. Спробуйте "
"ще раз або заповніть їх вручну."

#: app/messages.py:47 app/submission.py:268
msgid "Could not load price data. Check your internet connection and try again."
msgstr ""
"Не вдалося завантажити дані про ціни. Перевірте підключення до інтернету "
"та спробуйте ще раз."

#: app/submission.py:252
msgid "Spreadsheet generated"
msgstr "Таблицю сформовано"

#: app/submission.py:275
#, python-format
msgid "Error: %(err)s"
msgstr "Помилка: %(err)s"

#: app/ui_ops.py:79 app/ui_ops.py:81
msgid "Yes"
msgstr "Так"

#: app/ui_ops.py:80 app/ui_ops.py:82
msgid "No"
msgstr "Ні"

#: app/ui_ops.py:88
msgid "Width"
msgstr "Ширина"

#: app/ui_ops.py:91
msgid "Height"
msgstr "Висота"

