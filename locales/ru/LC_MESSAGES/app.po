#: app/builder.py:25 app/ui_ops.py:73
msgid "Language"
msgstr "Язык"

#: app/builder.py:35 app/submission.py:57 app/ui_ops.py:64
msgid ""
"Does the design have personalization\n"
"(e.g., text from the client)?"
msgstr ""
"Дизайн имеет персонализацию\n"
"(например, текст от клиента)?"

#: app/builder.py:52 app/submission.py:48 app/ui_ops.py:62
msgid "Does the design have color variations?"
msgstr "Дизайн имеет вариации по цвету?"

#: app/builder.py:78 app/flat_maker.py:296 app/messages.py:25 app/ui_ops.py:76
msgid "✨ Suggest title & keywords"
msgstr "✨ Предложить название и ключевую фразу"

#: app/builder.py:97 app/submission.py:281 app/ui_ops.py:78
msgid "Generate Spreadsheet"
msgstr "Сформировать таблицу"

#: app/builder.py:115 app/ui_ops.py:66
msgid "Sizes"
msgstr "Размеры"

#: app/builder.py:117 app/ui_ops.py:67
msgid "Print Type"
msgstr "Тип печати"

#: app/builder.py:120 app/ui_ops.py:68
msgid "Decals"
msgstr "Декали"

#: app/builder.py:121 app/ui_ops.py:69
msgid "Wallpapers"
msgstr "Обои"

#: app/builder.py:127 app/ui_ops.py:70
msgid "Listing Title"
msgstr "Название листинга"

#: app/builder.py:135 app/ui_ops.py:72
msgid "e.g.: VN007"
msgstr "Например: VN007"

#: app/builder.py:140 app/ui_ops.py:74
msgid "Keywords"
msgstr "Ключевая фраза"

#: app/builder.py:142 app/ui_ops.py:56
msgid "e.g. (in plural): Dog Wall Stickers"
msgstr "Например (во множ. ч.): Dog Wall Stickers"

#: app/flat_maker.py:252 app/messages.py:23
#, python-format
msgid "Enter a valid URL for %(field)s."
msgstr "Введите корректный URL для %(field)s."

#: app/flat_maker.py:253 app/ui_ops.py:98 app/ui_ops.py:165
msgid "Image Link"
msgstr "Ссылка на изображение"

#: app/flat_maker.py:263 app/messages.py:26 app/submission.py:209
msgid "Generating..."
msgstr "Генерация..."

#: app/flat_maker.py:275 app/messages.py:27
msgid "Title and keywords generated"
msgstr "Название и ключевая фраза сгенерированы"

#: app/flat_maker.py:288 app/messages.py:45
msgid ""
"AI could not generate a title and keywords. Try again or fill them "
"manually."
msgstr ""
"AI не смог сгенерировать название и ключевую фразу. Попробуйте еще раз "
"или заполните их вручную."

#: app/flat_maker.py:325
#, python-format
msgid "Please choose Yes or No for %(field)s."
msgstr "Пожалуйста, выберите Да или Нет для %(field)s."

#: app/flat_maker.py:423
msgid "Choose a folder to save the file"
msgstr "Выберите папку для сохранения файла"

#: app/messages.py:12
msgid ""
"Image Link #1 warning: the design must cover at least 75 percent of the "
"full room/staged image."
msgstr ""
"Предупреждение для Ссылки на изображение #1: дизайн должен занимать не "
"менее 75 процентов всего изображения комнаты или сцены."

#: app/messages.py:14
msgid "Press Enter to autofill."
msgstr "Enter = автозап."

#: app/messages.py:16
msgid ""
"Please fill in the required fields and choose the required options, and "
"enter valid values in the highlighted fields."
msgstr ""
"Пожалуйста, заполните обязательные поля и выберите обязательные опции, а "
"также введите корректные значения в выделенные поля."

#: app/messages.py:18
msgid "Please fill in the required fields and choose the required options."
msgstr "Пожалуйста, заполните обязательные поля и выберите обязательные опции."

#: app/messages.py:19
msgid "Please enter valid values in the highlighted fields."
msgstr "Пожалуйста, введите корректные значения в выделенные поля."

#: app/messages.py:20
msgid "Please fix the highlighted fields."
msgstr "Пожалуйста, исправьте выделенные поля."

#: app/messages.py:21
#, python-format
msgid "%(field)s is required."
msgstr "Поле %(field)s обязательно для заполнения."

#: app/messages.py:22
#, python-format
msgid "Links are not allowed in %(field)s."
msgstr "Ссылки не допускаются в поле %(field)s."

#: app/messages.py:24 app/ui_ops.py:55
msgid "e.g. (in plural): Dog Wallpapers"
msgstr "Например (во множ. ч.): Dog Wallpapers"

#: app/messages.py:28
msgid "AI generation is not configured. Please contact the administrator."
msgstr "AI-генерация не настроена. Обратитесь к администратору."

#: app/messages.py:29
msgid "AI text generation is not configured. Standard template text was used."
msgstr "AI-генерация текста не настроена. Использован стандартный шаблонный текст."

#: app/messages.py:30
msgid ""
"AI generation is not configured correctly. Please contact the "
"administrator."
msgstr "AI-генерация настроена некорректно. Обратитесь к администратору."

#: app/messages.py:31
msgid "AI limit was reached. Try again later."
msgstr "Лимит AI исчерпан. Попробуйте позже."

#: app/messages.py:32
msgid "AI limit was reached. Standard template text was used. Try again later."
msgstr ""
"Лимит AI исчерпан. Использован стандартный шаблонный текст. Попробуйте "
"позже."

#: app/messages.py:33
msgid "AI service is temporarily unavailable. Try again later."
msgstr "AI-сервис временно недоступен. Попробуйте позже."

#: app/messages.py:34
msgid "AI service is temporarily unavailable. Standard template text was used."
msgstr "AI-сервис временно недоступен. Использован стандартный шаблонный текст."

#: app/messages.py:35
msgid "AI generation failed. Try again later."
msgstr "AI-генерация не удалась. Попробуйте позже."

#: app/messages.py:36
msgid "AI generation failed. Standard template text was used."
msgstr "AI-генерация не удалась. Использован стандартный шаблонный текст."

#: app/messages.py:37 app/submission.py:114
msgid "AI text generation failed. Standard template text was used."
msgstr "AI-генерация текста не удалась. Использован стандартный шаблонный текст."

#: app/messages.py:38
msgid ""
"AI could not download the main image. Check that the image link opens "
"publicly."
msgstr ""
"AI не смог загрузить главное изображение. Проверьте, что ссылка на "
"изображение открывается публично."

#: app/messages.py:39
msgid "AI could not read the main image. Please use another image link."
msgstr "AI не смог прочитать главное изображение. Используйте другую ссылку."

#: app/messages.py:40
msgid "The main image is too large for AI analysis. Please use a smaller image."
msgstr ""
"Главное изображение слишком большое для AI-анализа. Используйте "
"изображение меньшего размера."

#: app/messages.py:41
msgid "AI did not return usable text. Try again."
msgstr "AI не вернул подходящий текст. Попробуйте еще раз."

#: app/messages.py:42
msgid "AI returned an unexpected answer. Try again."
msgstr "AI вернул неожиданный ответ. Попробуйте еще раз."

#: app/messages.py:43
msgid "AI returned incomplete text. Try again."
msgstr "AI вернул неполный текст. Попробуйте еще раз."

#: app/messages.py:44
msgid ""
"AI could not create a title and keywords from this image. Try again or "
"fill them manually."
msgstr ""
"AI не смог создать название и ключевую фразу по этому изображению. "
"Попробуйте еще раз или заполните их вручную."

#: app/messages.py:47 app/submission.py:268
msgid "Could not load price data. Check your internet connection and try again."
msgstr ""
"Не удалось загрузить данные о ценах. Проверьте подключение к интернету и "
"попробуйте снова."

#: app/submission.py:252
msgid "Spreadsheet generated"
msgstr "Таблица сформирована"

#: app/submission.py:275
#, python-format
msgid "Error: %(err)s"
msgstr "Ошибка: %(err)s"

#: app/ui_ops.py:79 app/ui_ops.py:81
msgid "Yes"
msgstr "Да"

#: app/ui_ops.py:80 app/ui_ops.py:82
msgid "No"
msgstr "Нет"

#: app/ui_ops.py:88
msgid "Width"
msgstr "Ширина"

#: app/ui_ops.py:91
msgid "Height"
msgstr "Высота"

