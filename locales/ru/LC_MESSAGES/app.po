#: app/flat_maker.py:178
#, python-format
msgid "Please choose Yes or No for %(field)s."
msgstr "Пожалуйста, выберите Да или Нет для %(field)s."

#: app/flat_maker.py:246
msgid "Choose a folder to save the file"
msgstr "Выберите папку для сохранения файла"

#: app/messages.py:6
msgid ""
"Image Link #1 warning: the design must cover at least 75 percent of the "
"full room/staged image."
msgstr ""
"Предупреждение для Ссылки на изображение #1: дизайн должен занимать не менее 75 "
"процентов всего изображения комнаты или сцены."

#: app/messages.py:7
msgid "Press Enter to autofill."
msgstr "Enter = автозап."

#: app/messages.py:8
msgid ""
"Please fill in the required fields and choose the required options, and "
"enter valid values in the highlighted fields."
msgstr ""
"Пожалуйста, заполните обязательные поля и выберите обязательные опции, а "
"также введите корректные значения в выделенные поля."

#: app/messages.py:9
msgid "Please fill in the required fields and choose the required options."
msgstr "Пожалуйста, заполните обязательные поля и выберите обязательные опции."

#: app/messages.py:10
msgid "Please enter valid values in the highlighted fields."
msgstr "Пожалуйста, введите корректные значения в выделенные поля."

#: app/messages.py:11
msgid "Please fix the highlighted fields."
msgstr "Пожалуйста, исправьте выделенные поля."

#: app/messages.py:12
#, python-format
msgid "%(field)s is required."
msgstr "Поле %(field)s обязательно для заполнения."

#: app/messages.py:13
#, python-format
msgid "Links are not allowed in %(field)s."
msgstr "Ссылки не допускаются в поле %(field)s."

#: app/messages.py:14
#, python-format
msgid "Enter a valid URL for %(field)s."
msgstr "Введите корректный URL для %(field)s."

